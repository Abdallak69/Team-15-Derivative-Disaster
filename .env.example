# Copy this file to `.env`, set real secrets, and lock it down with `chmod 600 .env`.
# Keep tuneable runtime parameters in `config/strategy_params.yaml`, not here.
# Telegram secrets are optional for local startup and polling smoke tests.
# Add them only after the bot installs, imports, and polls correctly.

# Roostoo API secrets
ROOSTOO_API_KEY=replace_me
ROOSTOO_SECRET_KEY=replace_me

# Telegram monitoring secrets
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me

# Optional: Override the runtime environment from strategy_params.yaml
# ENVIRONMENT=development

# Optional: Override the Roostoo API base URL
# ROOSTOO_BASE_URL=https://mock-api.roostoo.com
