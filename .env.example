# Roostoo API
# Replace these placeholders before running `python -m bot.main --startup-check`.
ROOSTOO_API_KEY=replace_me
ROOSTOO_SECRET_KEY=replace_me
ROOSTOO_BASE_URL=https://mock-api.roostoo.com

# Telegram monitoring
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me

# Runtime
ENVIRONMENT=development
POLL_INTERVAL_SECONDS=60
LOG_LEVEL=INFO
